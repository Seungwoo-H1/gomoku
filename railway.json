[prisma]
provider = "postgresql"

[[services]]
name = "gomoku-backend"
type = "web"
plan = "standard"
startCommand = "cd backend && npm run prisma:migrate && npm start"
buildCommand = "cd backend && npm ci && npm run build"
healthcheckPath = "/api/health"
healthcheckPeriod = "2m"
healthcheckTimeout = "30s"
healthcheckRestartPeriod = "1m"
healthcheckRestartThreshold = 5
ports = [
  { port = 4000, protocol = "tcp" }
]

[vars]
PORT = "4000"
NODE_ENV = "production"
CORS_ORIGIN = "https://gomoku.vercel.app"
DATABASE_URL = "postgresql://..."
